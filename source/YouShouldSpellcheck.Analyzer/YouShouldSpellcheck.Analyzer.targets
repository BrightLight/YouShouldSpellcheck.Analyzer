<Project>
  <PropertyGroup>
    <!-- Semicolons are not safe inside generated analyzer-config values. Encode after
         the consuming project has evaluated its own properties. -->
    <YouShouldSpellcheckDictionaryMappingsEncoded>$(YouShouldSpellcheckDictionaryMappings.Replace(';', '|'))</YouShouldSpellcheckDictionaryMappingsEncoded>
    <YouShouldSpellcheckLanguageToolMappingsEncoded>$(YouShouldSpellcheckLanguageToolMappings.Replace(';', '|'))</YouShouldSpellcheckLanguageToolMappingsEncoded>
    <YouShouldSpellcheckDefaultLanguagesEncoded>$(YouShouldSpellcheckDefaultLanguages.Replace(';', '|'))</YouShouldSpellcheckDefaultLanguagesEncoded>
    <YouShouldSpellcheckIdentifierLanguagesEncoded>$(YouShouldSpellcheckIdentifierLanguages.Replace(';', '|'))</YouShouldSpellcheckIdentifierLanguagesEncoded>
    <YouShouldSpellcheckClassNameLanguagesEncoded>$(YouShouldSpellcheckClassNameLanguages.Replace(';', '|'))</YouShouldSpellcheckClassNameLanguagesEncoded>
    <YouShouldSpellcheckMethodNameLanguagesEncoded>$(YouShouldSpellcheckMethodNameLanguages.Replace(';', '|'))</YouShouldSpellcheckMethodNameLanguagesEncoded>
    <YouShouldSpellcheckVariableNameLanguagesEncoded>$(YouShouldSpellcheckVariableNameLanguages.Replace(';', '|'))</YouShouldSpellcheckVariableNameLanguagesEncoded>
    <YouShouldSpellcheckPropertyNameLanguagesEncoded>$(YouShouldSpellcheckPropertyNameLanguages.Replace(';', '|'))</YouShouldSpellcheckPropertyNameLanguagesEncoded>
    <YouShouldSpellcheckEnumNameLanguagesEncoded>$(YouShouldSpellcheckEnumNameLanguages.Replace(';', '|'))</YouShouldSpellcheckEnumNameLanguagesEncoded>
    <YouShouldSpellcheckEnumMemberNameLanguagesEncoded>$(YouShouldSpellcheckEnumMemberNameLanguages.Replace(';', '|'))</YouShouldSpellcheckEnumMemberNameLanguagesEncoded>
    <YouShouldSpellcheckEventNameLanguagesEncoded>$(YouShouldSpellcheckEventNameLanguages.Replace(';', '|'))</YouShouldSpellcheckEventNameLanguagesEncoded>
    <YouShouldSpellcheckCommentLanguagesEncoded>$(YouShouldSpellcheckCommentLanguages.Replace(';', '|'))</YouShouldSpellcheckCommentLanguagesEncoded>
    <YouShouldSpellcheckStringLiteralLanguagesEncoded>$(YouShouldSpellcheckStringLiteralLanguages.Replace(';', '|'))</YouShouldSpellcheckStringLiteralLanguagesEncoded>
  </PropertyGroup>
  <ItemGroup>
    <CompilerVisibleProperty Include="YouShouldSpellcheckAttributeArgumentsEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckDictionaryMappingsEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckLanguageToolMappingsEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckDefaultLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckIdentifierLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckClassNameLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckMethodNameLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckVariableNameLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckPropertyNameLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckEnumNameLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckEnumMemberNameLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckEventNameLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckCommentLanguagesEncoded" />
    <CompilerVisibleProperty Include="YouShouldSpellcheckStringLiteralLanguagesEncoded" />
  </ItemGroup>
  <Target Name="_YouShouldSpellcheckCollectAttributeArguments"
          BeforeTargets="GenerateMSBuildEditorConfigFileCore">
    <PropertyGroup>
      <!-- AttributeType~Member~Kind~Languages records. The outer pipe and inner comma
           separators are safe in generated analyzer-config values. -->
      <YouShouldSpellcheckAttributeArgumentsEncoded>@(YouShouldSpellcheckAttributeArgument->'%(Identity)~%(Member)~%(Kind)~%(Languages)', '|')</YouShouldSpellcheckAttributeArgumentsEncoded>
      <YouShouldSpellcheckAttributeArgumentsEncoded>$(YouShouldSpellcheckAttributeArgumentsEncoded.Replace(';', ','))</YouShouldSpellcheckAttributeArgumentsEncoded>
    </PropertyGroup>
  </Target>
  <ItemGroup>
    <AdditionalFiles
      Include="$(MSBuildProjectDirectory)/CustomDictionary.*.txt"
      Exclude="@(AdditionalFiles)" />
  </ItemGroup>
</Project>
